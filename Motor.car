<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Auto Care Affiliate</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}

body{
    background:#f8f9fc;
    color:#333;
}

/* NAVBAR */
nav{
    background:#111;
    padding:20px 8%;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav h2{
    color:#00d9ff;
}

nav ul{
    display:flex;
    list-style:none;
    gap:30px;
}

nav ul li a{
    color:white;
    text-decoration:none;
}

/* HERO */
.hero{
    min-height:80vh;
    background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
    url("https://images.unsplash.com/photo-1503376780353-7e6692767b70");
    background-size:cover;
    background-position:center;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
    padding:20px;
}

.hero h1{
    font-size:55px;
    margin-bottom:20px;
}

.hero p{
    font-size:20px;
    margin-bottom:30px;
}

.btn{
    background:#ff0050;
    color:white;
    padding:14px 30px;
    text-decoration:none;
    border-radius:30px;
    font-weight:bold;
}

/* PRODUCTS */
.products{
    padding:80px 8%;
    text-align:center;
}

.products h2{
    margin-bottom:50px;
    font-size:38px;
}

.product-grid{
    display:grid;
    grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
    gap:30px;
}

.card{
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 5px 20px rgba(0,0,0,.1);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-10px);
}

.card img{
    width:100%;
    height:250px;
    object-fit:cover;
}

.card-content{
    padding:25px;
}

.card h3{
    margin-bottom:10px;
}

.price{
    color:green;
    font-size:22px;
    font-weight:bold;
    margin:15px 0;
}

.buy-btn{
    background:#000;
    color:white;
    padding:10px 20px;
    text-decoration:none;
    border-radius:25px;
}

/* BENEFITS */
.benefits{
    background:#111;
    color:white;
    padding:70px 8%;
    text-align:center;
}

.benefits h2{
    margin-bottom:40px;
}

.benefit-box{
    display:grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.box{
    background:#222;
    padding:30px;
    border-radius:15px;
}

/* FOOTER */
footer{
    background:black;
    color:white;
    text-align:center;
    padding:20px;
}

@media(max-width:768px){
    nav{
        flex-direction:column;
        gap:15px;
    }

    .hero h1{
        font-size:38px;
    }
}

</style>
</head>

<body>

<!-- NAVBAR -->
<nav>
    <h2>AutoCare Shop</h2>

    <ul>
        <li><a href="#">Home</a></li>
        <li><a href="#">Products</a></li>
        <li><a href="#">Reviews</a></li>
        <li><a href="#">Contact</a></li>
    </ul>
</nav>


<!-- HERO -->
<section class="hero">

    <div>
        <h1>Best Car & Motor Care Products</h1>

        <p>Trending TikTok Affiliate Products For Vehicle Lovers 🚗🏍️</p>

        <a href="#" class="btn">Shop Now</a>
    </div>

</section>


<!-- PRODUCTS -->
<section class="products">

    <h2>Featured Products</h2>

    <div class="product-grid">

        <!-- PRODUCT 1 -->
        <div class="card">
            <img src="https://images.unsplash.com/photo-1607860108855-64acf2078ed9" alt="Car Ceramic Spray">

            <div class="card-content">
                <h3>Car Ceramic Spray</h3>
                <p>Protect your car paint with long lasting shine and water repellent coating.</p>

                <div class="price">RM39.90</div>

                <a href="#" class="buy-btn">Buy on TikTok</a>
            </div>
        </div>


        <!-- PRODUCT 2 -->
        <div class="card">
            <img src="https://images.unsplash.com/photo-1580273916550-e323be2ae537" alt="Dashboard Coating">

            <div class="card-content">
                <h3>Dashboard Coating</h3>
                <p>Restore faded dashboard and keep interior looking premium.</p>

                <div class="price">RM29.90</div>

                <a href="#" class="buy-btn">Buy on TikTok</a>
            </div>
        </div>


        <!-- PRODUCT 3 -->
        <div class="card">
            <img src="https://images.unsplash.com/photo-1558981806-ec527fa84c39" alt="Motor Coating">

            <div class="card-content">
                <h3>Motor Coating</h3>
                <p>Special coating to keep your motorcycle glossy and protected.</p>

                <div class="price">RM35.90</div>

                <a href="#" class="buy-btn">Buy on TikTok</a>
            </div>
        </div>

    </div>

</section>


<!-- BENEFITS -->
<section class="benefits">

    <h2>Why Buy From Us?</h2>

    <div class="benefit-box">

        <div class="box">
            <h3>🔥 Viral Products</h3>
            <p>Only trending TikTok Shop products.</p>
        </div>

        <div class="box">
            <h3>⭐ Trusted Quality</h3>
            <p>Tested automotive products for daily use.</p>
        </div>

        <div class="box">
            <h3>💰 Best Price</h3>
            <p>Affordable deals with TikTok discounts.</p>
        </div>

    </div>

</section>


<!-- FOOTER -->
<footer>

    <p>© 2026 AutoCare Affiliate | Car & Motor Care Products</p>

</footer>
